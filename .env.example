# Relowa POC — environment variables
# Copy this file to .env and fill in the values.
# .env is git-ignored.

# Postgres
DATABASE_URL=postgres://relowa:dev_password_change_me@localhost:5433/relowa
POSTGRES_USER=relowa
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=relowa

# Realtime (only used by frontend client)
REALTIME_URL=ws://localhost:4000/socket
REALTIME_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiJ9.placeholder

# JWT (used by Hono backend to sign session tokens)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# LocalStack (S3, EventBridge, Lambda, SES mock)
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=eu-central-1
S3_BUCKET=relowa-files
