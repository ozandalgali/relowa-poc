# ─── Bastion host — SSH tunnel to private RDS ────────────────────────
# A t4g.nano EC2 in the public subnet that lets you SSH-tunnel to RDS
# from any IP. Costs ~$4/mo.

# Latest Amazon Linux 2023 ARM AMI
data "aws_ami" "amazon_linux_2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023*-kernel-6.1-x86_64"]
  }
}

# SSH key — generated by Terraform, private key stored in Secrets Manager
resource "tls_private_key" "bastion" {
  algorithm = "ED25519"
}

resource "aws_key_pair" "bastion" {
  key_name   = "relowa-${var.environment}-bastion"
  public_key = tls_private_key.bastion.public_key_openssh
}

resource "aws_secretsmanager_secret" "bastion_ssh_key" {
  name        = "/relowa/${var.environment}/bastion/ssh-private-key"
  description = "Bastion ED25519 private key for ${var.environment}"
}

resource "aws_secretsmanager_secret_version" "bastion_ssh_key" {
  secret_id     = aws_secretsmanager_secret.bastion_ssh_key.id
  secret_string = tls_private_key.bastion.private_key_openssh
}

# Security group — SSH from anywhere (key-only auth, no passwords)
resource "aws_security_group" "bastion" {
  name        = "relowa-${var.environment}-bastion-sg"
  description = "Bastion host - SSH access"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "SSH from anywhere (key-only auth)"
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "relowa-${var.environment}-bastion-sg" }
}

# Elastic IP — persistent public address
resource "aws_eip" "bastion" {
  domain = "vpc"
  tags   = { Name = "relowa-${var.environment}-bastion-eip" }
}

# EC2 instance
resource "aws_instance" "bastion" {
  ami                    = data.aws_ami.amazon_linux_2023.id
  instance_type          = "t3.micro"
  subnet_id              = aws_subnet.public[0].id
  vpc_security_group_ids = [aws_security_group.bastion.id]
  key_name               = aws_key_pair.bastion.key_name
  associate_public_ip_address = true

  root_block_device {
    volume_type = "gp3"
    volume_size = 8
    encrypted   = true
  }

  user_data = <<-EOF
    #!/bin/bash
    dnf install -y postgresql16
    echo "Bastion ready — connect: ssh -i <key> ec2-user@$(curl -s http://169.254.169.254/latest/meta-data/public-ipv4)"
  EOF

  tags = { Name = "relowa-${var.environment}-bastion" }

  lifecycle {
    ignore_changes = [associate_public_ip_address]
  }
}

# Attach EIP to bastion
resource "aws_eip_association" "bastion" {
  instance_id   = aws_instance.bastion.id
  allocation_id = aws_eip.bastion.id
}
